#!/bin/bash
#     __ _   _       
#    / _| |_| |_ ___ 
#   | |_| __| __/ __|
#   |  _| |_| |_\__ \
#   |_|  \__|\__|___/                 
#
# ftts - A simple text-to-speech wrapper for Festival.
#
# Project: https://github.com/galaxy-cli/ftts

# --- DEPENDENCY ftts ---
missing=()
for cmd in festival xsel; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        missing+=("$cmd")
    fi
done

if [ "${#missing[@]}" -gt 0 ]; then
    echo "ftts: error: The following dependencies are missing: ${missing[*]}" >&2
    read -rp "Would you like to install them via apt? [Y/n] " yn
    yn=${yn:-Y}

    if [[ $yn =~ ^[Yy]$ ]]; then
        sudo apt update && sudo apt install -y "${missing[@]}"
    else
        echo "ftts: error: cannot continue without required dependencies" >&2
        exit 1
    fi
fi

# --- USAGE ---
usage() {
    cat <<EOF
USAGE
  ftts [OPTION]

DESCRIPTION
  Converts text to speech using the Festival engine

OPTION
  -h, --help          Show this help message
  -c, --clipboard     Use clipboard (xsel)
  -f, --file FILE     Use specified text file
  -s, --speak TEXT    Speak the provided string (must be in quotes)
EOF
}

# --- INITIALIZE ---
input_source=""
file_path=""

# --- ARGUMENT PARSING ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--clipboard)
            [[ -n "$input_source" ]] && { echo "ftts: error: multiple input sources specified" >&2; exit 1; }
            input_source="clipboard"
            shift
            ;;
        -f|--file)
            [[ -n "$input_source" ]] && { echo "ftts: error: multiple input sources specified" >&2; exit 1; }
            [[ -z "$2" || "$2" == -* ]] && { echo "ftts: error: --file requires a filename" >&2; exit 1; }
            input_source="file"
            file_path="$2"
            shift 2
            ;;
        -s|--speak)
            [[ -z "$2" || "$2" == -* ]] && { echo "ftts: error: --speak requires a quoted string" >&2; exit 1; }
            if [[ -n "$3" && "$3" != -* ]]; then
                echo "ftts: error: multi-word strings must be enclosed in double quotes" >&2
                echo "Example: ftts -s \"hello world\"" >&2
                exit 1
            fi
            input_source="string"
            text="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "ftts: error: unknown option '$1'" >&2
            echo "Try 'ftts --help' for more information" >&2
            exit 1
            ;;
    esac
done

# --- VALIDATION ---
if [[ -z "$input_source" ]]; then
    echo "ftts: error: no input source specified" >&2
    echo "Try 'ftts --help' for more information" >&2
    exit 1
fi

if [[ "$input_source" == "file" ]]; then
    if [[ ! -f "$file_path" || ! -r "$file_path" ]]; then
        echo "ftts: error: '$file_path' is not a readable regular file" >&2
        exit 1
    elif [[ $(file -b --mime-type "$file_path") != text/* ]]; then
        echo "ftts: error: '$file_path' is not a plaintext file" >&2
        exit 1
    fi
fi

# --- OPTIONS ---
case "$input_source" in
    file)
        if [[ ! -f "$file_path" || ! -r "$file_path" ]]; then
            echo "ftts: error: Cannot read file '$file_path'" >&2
            exit 1
        fi
        text="$(cat "$file_path")"
        ;;
    clipboard)
        text=$(xsel -b)
        ;;
    string)
        ;;
    *)
        echo "ftts: error: No valid input source specified" >&2
        usage
        exit 1
        ;;
esac

# --- EXECUTION ---
escaped_text=$(printf '%s' "$text" | sed 's/"/\\"/g')
(
  echo "(Parameter.set 'Duration_Stretch 0.7)"
  echo "(SayText \"$escaped_text\")"
) | festival --pipe